# Flask / App
FLASK_ENV=production
SECRET_KEY=please-change-me

# App port (container internal, exposed via compose)
APP_PORT=8000
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=30

# Mongo
# If using compose mongo service:
# MONGO_URI=mongodb://mongo:27017
# If using existing lab Mongo:
MONGO_URI=mongodb://localhost:27017 # e.g. mongodb://server-address:port
MONGO_DB=lab_inventory

# Admin gate (simple PIN to unlock admin UI)
ADMIN_PIN=123456

# Email (low stock alerts + summary emails)
SMTP_HOST=smtp.example.org
SMTP_PORT=587
SMTP_USERNAME=your-user
SMTP_PASSWORD=your-pass
SMTP_USE_SSL=false
SMTP_FROM="Stockroom <stockroom@example.org>"
ADMIN_EMAIL=manager@example.org

# Summary email scheduler (cron-ping secured token)
CRON_TOKEN=please-change-this-long-random-string
SUMMARY_DEFAULT_FREQUENCY=daily      # never|daily|weekly
SUMMARY_DEFAULT_HOUR_UTC=22          # 0-23
SUMMARY_DEFAULT_WEEKDAY=4            # 0=Mon..6=Sun (weekly)
